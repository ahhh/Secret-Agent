---
import Layout from '../../components/Layout.astro';
import games from '../../data/games.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Games">
  <div class="container">
    <p class="dim" style="font-size:0.75rem">// OPERATIONS REGISTRY</p>
    <h1>ACTIVE & ARCHIVED GAMES</h1>

    <div style="margin-top:1.5rem">
      {games.map(game => (
        <div class="card" style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap">
          <div>
            <p style="font-size:0.75rem;color:var(--dim);margin-bottom:0.25rem">{game.location} — {game.startDate}</p>
            <a href={`${base}/games/${game.slug}`} style="font-size:1rem;letter-spacing:0.05em">{game.title}</a>
            <p style="margin-top:0.5rem;color:var(--dim);font-size:0.85rem">{game.briefing.slice(0, 100)}…</p>
          </div>
          <div style="display:flex;flex-direction:column;gap:0.5rem;align-items:flex-end;flex-shrink:0">
            <span class={`badge badge-${game.status}`}>{game.status}</span>
            {game.status === 'active' && (
              <a href={`${base}/games/${game.slug}/join`} class="btn" style="font-size:0.7rem">JOIN</a>
            )}
            <a href={`${base}/games/${game.slug}/leaderboard`} class="btn" style="font-size:0.7rem">SCORES</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
